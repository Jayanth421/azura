# IMPORTANT:
# - Do NOT put real secrets in this file.
# - Local dev: copy to `server/.env` (gitignored).
# - Vercel: set these as Environment Variables in Project Settings.

PORT=5174
# Use full origin with protocol (http/https)
FRONTEND_BASE_URL=http://127.0.0.1:5173

# MongoDB
# Example (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=azera

# Mail
# - smtp: use SMTP_HOST/SMTP_PORT/...
# - outbox: write emails to OUTBOX_DIR (useful for local dev)
MAIL_MODE=smtp
# OUTBOX_DIR=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional admin dashboard
ADMIN_TOKEN=

# Optional image hosting
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
